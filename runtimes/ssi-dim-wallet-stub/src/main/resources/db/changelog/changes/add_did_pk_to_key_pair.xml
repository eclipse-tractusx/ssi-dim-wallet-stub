<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

    <changeSet id="arnoweiss:1" author="arnoweiss">
        <addColumn tableName="key_pair">
            <column name="did" type="VARCHAR(255)" defaultValue="">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <dropPrimaryKey tableName="key_pair"/>
        <addPrimaryKey tableName="key_pair" columnNames="did" constraintName="key_pair_pkey"/>
        <dropNotNullConstraint tableName="key_pair" columnName="bpn" columnDataType="VARCHAR(255)"/>
        <rollback>
            <addNotNullConstraint tableName="key_pair" columnName="bpn" columnDataType="VARCHAR(255)"/>
            <dropPrimaryKey tableName="key_pair"/>
            <addPrimaryKey tableName="key_pair" columnNames="bpn" constraintName="key_pair_pkey"/>
            <dropColumn tableName="key_pair" columnName="did"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
